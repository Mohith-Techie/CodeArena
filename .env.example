# Environment Variables for CodeArena
# Copy this to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=codearena
POSTGRES_PASSWORD=codearena_secret_change_me
POSTGRES_DB=codearena

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── API Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
CODE_TIMEOUT_MS=10000

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_WS_URL=http://localhost:4000
