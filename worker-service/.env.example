# ──────────────────────────────────────────────
# CodeArena Worker Service – Environment Config
# ──────────────────────────────────────────────

# PostgreSQL connection string (shared with api-server)
DATABASE_URL="postgresql://codearena:codearena_pass@postgres:5432/codearena?schema=public"

# Redis connection (BullMQ queue + pub/sub)
REDIS_URL="redis://redis:6379"

# Number of concurrent submission jobs this worker handles simultaneously.
# Keep at 2-4 per worker replica; higher values increase Docker daemon pressure.
WORKER_CONCURRENCY=2
